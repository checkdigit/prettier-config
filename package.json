{
  "name": "@checkdigit/prettier-config",
  "version": "8.1.0",
  "private": false,
  "description": "Check Digit code formatting configuration",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/checkdigit/prettier-config.git"
  },
  "license": "MIT",
  "author": "Check Digit, LLC",
  "type": "module",
  "main": "index.json",
  "files": [
    "index.json"
  ],
  "scripts": {
    "ci:compile": "",
    "ci:lint": "",
    "ci:style": "npm run prettier",
    "ci:test": "npm run ci:style && prettier --version | grep -q '3.9.4'",
    "prepare": "",
    "prettier": "prettier --list-different .",
    "prettier:fix": "prettier --write .",
    "test": "npm run ci:test"
  },
  "prettier": "./index.json",
  "peerDependencies": {
    "@prettier/plugin-oxc": "0.2.0",
    "@prettier/plugin-xml": "3.4.2",
    "prettier": "3.9.4",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-svelte": "4.1.1",
    "prettier-plugin-tailwindcss": "0.8.0"
  },
  "engines": {
    "node": ">=24.14.1"
  }
}
